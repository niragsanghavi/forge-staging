rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // ── GROUPS + SEASON SUBCOLLECTIONS ────────────────────────────────────
    match /groups/{groupCode} {
      allow read:  if isAuthed();
      allow write: if isAuthed();

      match /seasons/{sid} {
        allow read:  if isAuthed();
        allow write: if isAuthed();

        match /twists/{twistId} {
          allow read:  if isAuthed();
          allow write: if isAuthed();
        }

        // Iron Pledge bets — write-once per player per week
        match /bets/{playerName} {
          allow read:   if isAuthed();
          allow create: if isAuthed();
          allow update: if false;
          allow delete: if false;
        }

        // Jack of All Trades awards — written by client, never deleted
        match /jackAwards/{id} {
          allow read:  if isAuthed();
          allow write: if isAuthed();
          allow delete: if false;
        }

        // Week-bound twist windows (Boss Week / Underdog Week) — immutable once written
        match /twistWindows/{windowId} {
          allow read:   if isAuthed();
          allow create: if isAuthed();
          allow update: if false;
          allow delete: if false;
        }
      }
    }

    // ── S1 IDENTITY LAYER ──────────────────────────────────────────────────
    // request.auth.uid can't gate these writes: anonymous auth issues a new
    // uid per device, so uid == userId is never true across devices (PIN is
    // checked client-side, same posture as the roster today — narrower than
    // before since pinHash replaces plaintext, not wider). Real enforcement
    // needs custom-token auth (AUTH_UPGRADE.md); not this sprint.
    match /users/{userId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if false;

      // Path reserved for the future S2 snapshot writer — not built yet.
      // Create-only: season archives are immutable from the moment they exist.
      match /seasons/{seasonKey} {
        allow read:   if isAuthed();
        allow create: if isAuthed();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── TOP-LEVEL LOG COLLECTIONS ─────────────────────────────────────────
    // Tombstone model (NORTHSTAR §5.3): a log is never truly deletable —
    // "removing" one just sets voided/voidedBy/voidedAt, and every read site
    // in the app filters voided:true out. update is scoped to EXACTLY those
    // three fields so a void can never be used to rewrite a log's actual
    // content (workouts/day/player/etc are frozen from the moment of create).
    match /logs/{id} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow delete: if false;
      allow update: if isAuthed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voided','voidedBy','voidedAt']);
    }

    match /bonuses_30day/{id} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if false;
      allow delete: if false;
    }

    match /flags/{id} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow delete: if isAuthed();
      allow update: if false;
    }

    // S5 §7.1: 🔥 reactions — deterministic {logId}_{sanitizedPlayer} IDs make
    // create-then-delete the whole lifecycle; never updated (there's nothing
    // to edit about a reaction, just add or remove it).
    match /reactions/{id} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow delete: if isAuthed();
      allow update: if false;
    }

    // Iron Pledge results — written by admin action, immutable thereafter
    match /bonuses_iron_pledge/{id} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if false;
      allow delete: if false;
    }

    // ── ANALYTICS ─────────────────────────────────────────────────────────
    // Top-level doc per group — never written directly
    match /analytics/{groupCode} {
      allow read:  if isAuthed();
      allow write: if false;

      // Tab click counters — clients increment via merge, super admin reads
      match /tabClicks/{month} {
        allow read:   if isAuthed();
        allow create: if isAuthed();
        allow update: if isAuthed();
        allow delete: if false;
      }

      // NOTE: baseline-{YYYY-MM} aggregates are top-level analytics/ DOCS, so
      // the parent match above already covers them (read authed, write denied).
      // A previous nested `match /baseline-{docId}` block was invalid syntax —
      // literal-prefix wildcards aren't allowed — and made this whole file
      // undeployable, which is why deployed rules had drifted from the repo.
    }

    // Updates page analytics — public landing page, so writes are unauthenticated
    // (visitors may not have Firebase anonymous auth initialized yet). Reads stay gated.
    match /analytics/updates-page/events/{month} {
      allow read:   if isAuthed();
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── DEFAULT DENY ──────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
